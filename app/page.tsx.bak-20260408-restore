    setGptMessages((prev) => [
      ...prev,
      {
        id: generateId(),
        role: "gpt",
        text: `笨・譁ｰ縺励＞Kin繧ｿ繧ｹ繧ｯ繧堤函謌舌＠縺ｦKin蜈･蜉帶ｬ・↓繧ｻ繝・ヨ縺励∪縺励◆縲５ASK_ID: #${started.taskId}`,
        meta: {
